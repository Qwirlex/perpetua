# Perpetua config. With nothing set the demo runs end to end on local settlement.
# Set PERPETUA_LIVE=1 plus the live values below to settle on Base for real.

# Master switch for live integrations. 0 or unset runs the safe local demo.
PERPETUA_LIVE=0

# MongoDB Atlas, the ledger and memory store, and the sponsor integration.
# Leave empty to use the local JSON file ledger instead.
MONGODB_URI=
MONGODB_DB=perpetua

# Base settlement and the on chain ledger mirror.
BASE_RPC_URL=
X402_NETWORK=base-sepolia
# Base Sepolia USDC by default, override for mainnet.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# The agent identity that receives signal sales. Generated in memory if unset.
AGENT_PRIVATE_KEY=
# Key that writes the on chain ledger mirror. Generated in memory if unset.
MIRROR_PRIVATE_KEY=

# Research LLM, the compute the agent pays for. none runs the deterministic analyst rationale.
# Options, none, gemini, anthropic.
LLM_PROVIDER=none
GEMINI_MODEL=gemini-3.5-flash
GOOGLE_CLOUD_PROJECT=
ANTHROPIC_API_KEY=

# Real market data feed. Empty uses the seeded synthetic market.
MARKET_DATA_URL=

# Ports and cadence.
MARKET_PORT=4021
API_PORT=4022
CYCLE_MS=6000
BUYERS_PER_CYCLE=3
ASSET=ETH
